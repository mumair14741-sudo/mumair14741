# ============================================================
#  RealFlow — Home PC Backend Environment (realflow.online)
#  Copy this file to `.env` in the PROJECT ROOT (next to
#  docker-compose.yml) and fill in the values marked <CHANGE_ME>.
# ============================================================

# ── Domains ─────────────────────────────────────────────────
# Public app URL (Vercel frontend). Used in password-reset emails,
# postback URLs, etc.
APP_URL=https://realflow.online

# Who can call the backend. Add both naked + www + any Vercel
# preview URLs if you use them.
CORS_ORIGINS=https://realflow.online,https://www.realflow.online

# ── Database ────────────────────────────────────────────────
DB_NAME=realflow

# ── Admin seed (change AFTER first login!) ──────────────────
ADMIN_EMAIL=admin@realflow.online
ADMIN_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ── Security secrets ────────────────────────────────────────
# Generate each with:  openssl rand -hex 32
# (Windows:  powershell -c "[Convert]::ToHexString([byte[]](1..32|%{Get-Random -Max 255}))" )
JWT_SECRET_KEY=<CHANGE_ME_RANDOM_32_HEX>
POSTBACK_TOKEN=<CHANGE_ME_RANDOM_32_HEX>

# ── Email (optional — leave blank to disable email) ─────────
# Option A: Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Option B: Resend (https://resend.com) — easier, 3000 free emails/mo
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# ── Frontend port on home PC (optional) ────────────────────
# If you run docker frontend locally for testing, it binds here.
# Safe to leave at 3000.
FRONTEND_PORT=3000
